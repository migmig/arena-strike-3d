{
  "name": "arena-strike-3d",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "build-assets": "node scripts/build-assets.mjs",
    "deploy": "pnpm build && pnpm dlx wrangler pages deploy ./dist --project-name=arena-strike-3d"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.14.0",
    "howler": "^2.2.4",
    "seedrandom": "^3.0.5",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/howler": "^2.2.11",
    "@types/seedrandom": "^3.0.8",
    "@types/stats.js": "^0.17.4",
    "@types/three": "^0.160.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "lil-gui": "^0.19.2",
    "prettier": "^3.2.0",
    "stats.js": "^0.17.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.4.0"
  }
}
